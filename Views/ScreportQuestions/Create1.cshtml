@inject IHttpContextAccessor HttpContextAccessor
@using Microsoft.AspNetCore.Http;
@model CSMS.Models.ScreportQuestion

@{
    ViewData["Title"] = "Create";
}
<br />
<div class="container">
    <div class="QuestionnairePageContainer">
        <br />
        <h2 class="center">Housing Conditions Survey</h2>
        <h6 class="center text-muted">To be completed by Survey Coordinator</h6>
