                        <table class="table">
                            <tr>
                                <th></th>
                                <th style="text-align: center">Outside City of Duty Station</th>
                                <th style="text-align: center">Within City of Duty Station</th>
                            </tr>
                            <tr>
                                <td>Commercial/Private Housing</td>
                                <td>
                                    <input asp-for="CommercialOutSide" class="form-control form-control-sm" />
                                    <span asp-validation-for="CommercialOutSide" class="text-danger"></span>

                                </td>
                                <td>
                                    <input asp-for="CommercialInSide" class="form-control form-control-sm" />
                                    <span asp-validation-for="CommercialInSide" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td>Government-Privided Housing</td>
                                <td>
