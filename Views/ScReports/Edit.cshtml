@inject IHttpContextAccessor HttpContextAccessor
@using Microsoft.AspNetCore.Http;
@model CSMS.Models.ScReport

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/theme/_ThemeLayout_Forms.cshtml";
}

    <div style="background-image: url(cold/assets/images/Banner.png);background-color:#203752;">
        <div class="card-body">
            <div class="text-center">

                <h2 class="card-title text-white" style="padding:40px 0 5px 0">Edit Survey Coordinator Questionnaire</h2>

                @{
                    string display = @HttpContextAccessor.HttpContext.Session.GetString("_loggedInUserCountry") + " - " + @HttpContextAccessor.HttpContext.Session.GetString("_loggedInUserCity");


                    <h4 class="card-title text-center text-white">
                        @*<h4 style="@(display? "disply:block" : "display:none")" class="card-title text-center text-white">*@
                        @display
                    </h4>

                    <br />


                }

            </div>
        </div>
    </div>




    <form asp-action="Edit" class="mt-4">
        <div class="row">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @*<input asp-for="Id" />*@
            <input type="hidden" asp-for="Syscode" />
            @*<input class="form-control" type="text" hidden data-val="true" data-val-length="The field Syscode must be a string with a maximum length of 13." data-val-length-max="13" id="Syscode" maxlength="13" name="Syscode" value="@HttpContextAccessor.HttpContext.Session.GetString("_Syscode")" />*@
            <div id="page1">
                <div class="card">
                    <div class="card-body">
                        <br /><br />
                        <h2 class="text-center card-title">HOUSING CONDITIONS</h2><br /><br />
                        <h3 class="text-center card-title">Please Indicate all applicable categories</h3><br />

                        <div class="row">
                            <div class="col-md-2">
                            </div>
                            <div class="col-md-8">
                                <div class="questionText">1. Please indicate all types of housing available in the duty station:</div>
                                <br /><br />
                                <table class="table">
                                    <tr>
                                        <th></th>
                                        <th>Outside City of Duty Station</th>
                                        <th>Within City of Duty Station</th>
                                    </tr>
                                    <tr>
                                        <td>Commercial/Private Housing <sup>1</sup></td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                <input type="checkbox" class="form-check-input" asp-for="CommercialOutSide" />
                                                <span asp-validation-for="CommercialOutSide" class="text-danger"></span>
                                            </div>


                                            @*<input asp-for="CommercialOutSide" class="form-control form-control-sm" />
                                                <span asp-validation-for="CommercialOutSide" class="text-danger"></span>*@

                                        </td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                <input type="checkbox" class="form-check-input" asp-for="CommercialInSide" />
                                                <span asp-validation-for="CommercialInSide" class="text-danger"></span>
                                            </div>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Government-Privided Housing</td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                <input type="checkbox" class="form-check-input" asp-for="GovtOutSide" />
                                                <span asp-validation-for="GovtOutSide" class="text-danger"></span>
                                            </div>
                                        </td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                @*<input type="checkbox" data-size="large" class="js-switch"*@
                                                <input type="checkbox" class="form-check-input" asp-for="GovtInSide" />
                                                <span asp-validation-for="GovtInSide" class="text-danger"></span>
                                            </div>
                                        </td>

                                    </tr>
                                    <tr>
                                        <td>UN-Agency-provided Housing</td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                <input type="checkbox" class="form-check-input" asp-for="UnoutSide" />
                                                <span asp-validation-for="UnoutSide" class="text-danger"></span>
                                            </div>

                                        </td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                <input type="checkbox" class="form-check-input" asp-for="UninSide" />
                                                <span asp-validation-for="UninSide" class="text-danger"></span>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Other: Specify
                                            <input asp-for="OtherHousing" class="form-control" />
                                        </td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                <input type="checkbox" class="form-check-input" asp-for="OtherHousingOutside" />
                                                <span asp-validation-for="OtherHousingOutside" class="text-danger"></span>
                                            </div>

                                        </td>
                                        <td>
                                            <div style="margin-left:40%" class="form-check mr-sm-2 mb-3">
                                                <input type="checkbox" class="form-check-input" asp-for="OtherHousingInside" />
                                                <span asp-validation-for="OtherHousingInside" class="text-danger"></span>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                                <sup>1</sup> Dwellings available on the open market

                                <br /><br />

                                @*HOUSING CONDITION SECTION ENDS*@



                                <input type="button" value="Next" class="btn btn-primary btn-block" onclick="getElementById('page1').style.display='none'; getElementById('page2').style.display='block';" />


                            </div>
                            <div class="col-md-2">
                            </div>
                        </div>
                    </div>
                </div>
            </div> @*Page 1*@

            <div id="page2">

                <div class="card">
                    <div class="card-body">

                        <br />
                        <h3 class="text-center card-title">Please rate quality and availability of housing</h3><br />

                        <br />
                        <div class="row">
                            <div class="col-md-2">
                            </div>
                            <div class="col-md-8">
                                <div class="questionText">2. Please select the value which best describes the following qualities of housing and facilities:</div>
                                <br /><br />
                                <table class="table table-sm">
                                    <tr>
                                        <th></th>
                                        <th style="text-align: center">Rating</th>
                                        <th style="text-align: center">Comments</th>
                                    </tr>



                                    <tr>
                                        <td> Overall Quality: </td>
                                        <td>

                                            <input type="text" asp-for="OverallQuality" class="form-control" id="Quality" hidden />


                                            <div class="star-rating">
                                                <input type="radio" id="Quality5-stars" name="Qualityrating" value="5" asp-for="OverallQuality" onclick="document.getElementById('Quality').value = this.value;" />
                                                <label for="Quality5-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Quality4-stars" name="Qualityrating" value="4" asp-for="OverallQuality" onclick="document.getElementById('Quality').value = this.value;" />
                                                <label for="Quality4-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Quality3-stars" name="Qualityrating" value="3" asp-for="OverallQuality" onclick="document.getElementById('Quality').value = this.value;" />
                                                <label for="Quality3-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Quality2-stars" name="Qualityrating" value="2" asp-for="OverallQuality" onclick="document.getElementById('Quality').value = this.value;" />
                                                <label for="Quality2-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Quality1-star" name="Qualityrating" value="1" asp-for="OverallQuality" onclick="document.getElementById('Quality').value = this.value;" />
                                                <label for="Quality1-star" class="star">&#9733;</label>
                                            </div>

                                        </td>

                                        <td>
                                            <div class="form-group" style="padding-top:10px">
                                                <input asp-for="OverallQualityComments" class="form-control" id="teswt" />
                                                <span asp-validation-for="OverallQualityComments" class="text-danger"></span>
                                            </div>
                                        </td>

                                    </tr>


                                    <tr>

                                        <td> Availability: </td>
                                        <td>
                                            <input type="text" asp-for="Availability" class="form-control" id="Available" hidden />
                                            <div class="star-rating">
                                                <input type="radio" id="Availability5-stars" name="Availabilityrating" value="5" asp-for="Availability" onclick="document.getElementById('Available').value = this.value;" />
                                                <label for="Availability5-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Availability4-stars" name="Availabilityrating" value="4" asp-for="Availability" onclick="document.getElementById('Available').value = this.value;" />
                                                <label for="Availability4-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Availability3-stars" name="Availabilityrating" value="3" asp-for="Availability" onclick="document.getElementById('Available').value = this.value;" />
                                                <label for="Availability3-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Availability2-stars" name="Availabilityrating" value="2" asp-for="Availability" onclick="document.getElementById('Available').value = this.value;" />
                                                <label for="Availability2-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Availability1-star" name="Availabilityrating" value="1" asp-for="Availability" onclick="document.getElementById('Available').value = this.value;" />
                                                <label for="Availability1-star" class="star">&#9733;</label>
                                            </div>
                                        </td>

                                        <td>
                                            <div class="form-group" style="padding-top:10px">
                                                <input asp-for="AvailabilityComments" class="form-control" />
                                                <span asp-validation-for="AvailabilityComments" class="text-danger"></span>
                                            </div>
                                        </td>

                                    </tr>



                                    <tr>
                                        <td> Maintenance level by landlord: </td>
                                        <td>
                                            <input type="text" asp-for="MaintenanceLevel" class="form-control" id="Maintenance" hidden />
                                            <div class="star-rating">
                                                <input type="radio" id="Maintenance5-stars" name="Maintenancerating" value="5" asp-for="MaintenanceLevel" onclick="document.getElementById('Maintenance').value = this.value;" />
                                                <label for="Maintenance5-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Maintenance4-stars" name="Maintenancerating" value="4" asp-for="MaintenanceLevel" onclick="document.getElementById('Maintenance').value = this.value;" />
                                                <label for="Maintenance4-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Maintenance3-stars" name="Maintenancerating" value="3" asp-for="MaintenanceLevel" onclick="document.getElementById('Maintenance').value = this.value;" />
                                                <label for="Maintenance3-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Maintenance2-stars" name="Maintenancerating" value="2" asp-for="MaintenanceLevel" onclick="document.getElementById('Maintenance').value = this.value;" />
                                                <label for="Maintenance2-stars" class="star">&#9733;</label>
                                                <input type="radio" id="Maintenance1-star" name="Maintenancerating" value="1" asp-for="MaintenanceLevel" onclick="document.getElementById('Maintenance').value = this.value;" />
                                                <label for="Maintenance1-star" class="star">&#9733;</label>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="form-group" style="padding-top:10px">
                                                <input asp-for="MaintenanceComments" class="form-control" />
                                                <span asp-validation-for="MaintenanceComments" class="text-danger"></span>
                                            </div>
                                        </td>
                                    </tr>




                                    <tr>

                                        <td>Time for Newcomer to find decent dwelling: </td>


                                        <td>
                                            <input type="text" asp-for="TimeForNewComer" class="form-control" id="NewComer" hidden />
                                            <div class="star-rating">
                                                <input type="radio" id="NewComer5-stars" name="NewComerrating" value="5" asp-for="TimeForNewComer" onclick="document.getElementById('NewComer').value = this.value;" />
                                                <label for="NewComer5-stars" class="star">&#9733;</label>
                                                <input type="radio" id="NewComer4-stars" name="NewComerrating" value="4" asp-for="TimeForNewComer" onclick="document.getElementById('NewComer').value = this.value;" />
                                                <label for="NewComer4-stars" class="star">&#9733;</label>
                                                <input type="radio" id="NewComer3-stars" name="NewComerrating" value="3" asp-for="TimeForNewComer" onclick="document.getElementById('NewComer').value = this.value;" />
                                                <label for="NewComer3-stars" class="star">&#9733;</label>
                                                <input type="radio" id="NewComer2-stars" name="NewComerrating" value="2" asp-for="TimeForNewComer" onclick="document.getElementById('NewComer').value = this.value;" />
                                                <label for="NewComer2-stars" class="star">&#9733;</label>
                                                <input type="radio" id="NewComer1-star" name="NewComerrating" value="1" asp-for="TimeForNewComer" onclick="document.getElementById('NewComer').value = this.value;" />
                                                <label for="NewComer1-star" class="star">&#9733;</label>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="form-group" style="padding-top:10px">
                                                <input asp-for="TimeForNewComerComments" class="form-control" />
                                                <span asp-validation-for="TimeForNewComerComments" class="text-danger"></span>
                                            </div>
                                        </td>
                                    </tr>


                                </table>

                                <br /><br />

                                <div class="questionText">3. Please describe usual practices with regard to key money, security, or other deposits:</div>
                                <div class="form-group">

                                    <textarea rows="3" asp-for="KeyMoneySecurityDeposit" class="form-control"></textarea>
                                    <span asp-validation-for="KeyMoneySecurityDeposit" class="text-danger"></span>
                                </div>



                                <input type="button" value="Back" class="btn btn-primary btn-block" onclick="getElementById('page2').style.display='none'; getElementById('page1').style.display='block';" />
                                <input type="button" value="Next" class="btn btn-primary btn-block" onclick="getElementById('page2').style.display='none'; getElementById('page3').style.display='block';" />

                            </div>

                            <div class="col-md-2">
                            </div>
                        </div>
                    </div>
                </div>

            </div> @*Page 2*@


            <div id="page3">

                <div class="card">
                    <div class="card-body">

                        <br />
                        <div class="row">
                            <div class="col-md-2">
                            </div>
                            <div class="col-md-8">
                                <br /><br />
                                <h2 class="text-center card-title">SECURITY COSTS</h2><br /><br />
                                <br /><br />
                                <div class="questionText">1. Is it necessary for staff members to incur additional costs for security reasons?</div><br />

                                @*<label asp-for="AdditionalSecurityCost" class="control-label"></label>*@
                                <table>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                <input id="additionalSecurityYes" type="radio" class="form-check-input" value="true" asp-for="AdditionalSecurityCost"
                                                       onclick="document.getElementById('reimbursed').style.display='block';" />
                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>Yes<br /></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                <input id="additionalSecurityNo" type="radio" class="form-check-input" value="false" asp-for="AdditionalSecurityCost"
                                                       onclick="document.getElementById('reimbursed').style.display = 'none'; document.getElementById('securityReimbursedYes').checked = false; document.getElementById('securityReimbursedNo').checked = false;" />
                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>No<br /></td>
                                    </tr>
                                </table>
                                <br /><br />


                                <div id="reimbursed">
                                    <div class="questionText">2. Is any portion of these costs reimbursed by the agencies?</div><br />




                                    @*<label asp-for="AdditionalSecurityCost" class="control-label"></label>*@

                                    <table>
                                        <tr>
                                            <td>
                                                <div class="custom-control custom-radio">
                                                    <input id="securityReimbursedYes" type="radio" class="form-check-input" value="true" asp-for="SecurityCostReimbursed" />
                                                </div>
                                            </td>
                                            <td> </td>
                                            <td>Yes<br /></td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <div class="custom-control custom-radio">
                                                    <input id="securityReimbursedNo" type="radio" class="form-check-input" value="false" asp-for="SecurityCostReimbursed" />
                                                </div>
                                            </td>
                                            <td> </td>
                                            <td>No<br /></td>
                                        </tr>
                                    </table>
                                </div>

                                <br /><br />



                                <br />
                                <br />
                                <input type="button" value="Back" class="btn btn-primary btn-block" onclick="getElementById('page3').style.display='none'; getElementById('page2').style.display='block';" />
                                <input type="button" value="Next" class="btn btn-primary btn-block" onclick="getElementById('page3').style.display='none'; getElementById('page4').style.display='block';" />
                            </div>
                            <div class="col-md-2">
                            </div>
                        </div>
                    </div>
                </div>
            </div> @*Page3*@

            <div id="page4">

                <div class="card">
                    <div class="card-body">

                        <br />
                        <div class="row">
                            <div class="col-md-2">
                            </div>
                            <div class="col-md-8">
                                <br /><br />
                                <h2 class="text-center card-title">DOMESTIC SERVICES</h2><br /><br />
                                <br /><br />
                                <div class="questionText">
                                    1. Is it common practice among international staff members to employ the services of domestic help?
                                </div><br />

                                @*<label asp-for="AdditionalSecurityCost" class="control-label"></label>*@



                                <table>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                <input id="domesticHelpYes" type="radio" class="form-check-input" value="true" asp-for="CommonToEmployDomestic" />
                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>Yes<br /></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                <input id="domesticHelpNo" type="radio" class="form-check-input" value="false" asp-for="CommonToEmployDomestic" />
                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>No<br /></td>
                                    </tr>
                                </table>
                                <br /><br />

                                <div id="socialInsurance">
                                    <div class="questionText">2. Does a social insurance scheme exist for citizens of this country?</div><br />


                                    @*  <input type="checkbox" class="js-switch" data-color="#009efb" asp-for="SocialInsuranceApplyToDomestic" />*@

                                    <table>
                                        <tr>
                                            <td>
                                                <div class="custom-control custom-radio">
                                                    <input id="domesticHelpYes" type="radio" class="form-check-input" value="true" asp-for="SocialInsuranceApplyToDomestic" />
                                                </div>
                                            </td>
                                            <td> </td>
                                            <td>Yes<br /></td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <div class="custom-control custom-radio">
                                                    <input id="domesticHelpNo" type="radio" class="form-check-input" value="false" asp-for="SocialInsuranceApplyToDomestic" />
                                                </div>
                                            </td>
                                            <td> </td>
                                            <td>No<br /></td>
                                        </tr>
                                    </table>

                                </div>
                                <br />
                                <br />

                                <div class="questionText">Any additional comments on security and domestic help</div>
                                <div class="form-group">

                                    <textarea rows="3" asp-for=" DomesticHelpComment" class="form-control"></textarea>
                                    <span asp-validation-for=" DomesticHelpComment" class="text-danger"></span>
                                </div>
                                <br />
                                <br />


                                <input type="button" value="Back" class="btn btn-primary btn-block" onclick="getElementById('page4').style.display='none'; getElementById('page3').style.display='block';" />
                                <input type="button" value="Next" class="btn btn-primary btn-block" onclick="getElementById('page4').style.display='none'; getElementById('page5').style.display='block';" />
                            </div>
                            <div class="col-md-2">
                            </div>
                        </div>
                    </div>
                </div>
            </div> @*Page4*@


            <div id="page5">
                <div class="card">
                    <div class="card-body">

                        <br />
                        <div class="row">
                            <div class="col-md-2">
                            </div>
                            <div class="col-md-8">
                                <br /><br />
                                <h2 class="text-center card-title">2.5 CURRENCY PAYMENTS AND LOCAL SALES TAXES</h2><br /><br />
                                <br /><br />
                                <div class="questionText">
                                    Do staff members make purchases in local stores using foreign currency?
                                </div><br />


                                <table>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                @* <input id="PurchaseForeinCurrencyYes" type="radio" class="form-check-input" value="true" asp-for="PurchaseUsingForeignCurrency" />*@
                                                <input id="PurchaseForeinCurrencyYes" type="radio" class="form-check-input" value="true" asp-for="PurchaseUsingForeignCurrency"
                                                       onclick="document.getElementById('currency').style.display='block';" />

                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>Yes<br /></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                @* <input id="PurchaseForeinCurrencyNo" type="radio" class="form-check-input" value="false" asp-for="PurchaseUsingForeignCurrency" />*@
                                                <input id="PurchaseForeinCurrencyNo" type="radio" class="form-check-input" value="false" asp-for="PurchaseUsingForeignCurrency"
                                                       onclick="document.getElementById('currency').style.display='none'; document.getElementById('singleCurrency').value=''; document.getElementById('listCurrency').value='';" />
                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>No<br /></td>
                                    </tr>
                                </table>


                                <br />
                                <div id="currency">
                                    <div class="form-group">
                                        <label @*asp-for="CurrencyName"*@ class="control-label">Please specify currency </label>
                                        <input id="singleCurrency" asp-for="CurrencyName" class="form-control" />
                                        <span asp-validation-for="CurrencyName" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="ListCurrencies" class="control-label">If multiple currencies, please list</label>
                                        <textarea id="listCurrency" rows="3" asp-for="ListCurrencies" class="form-control"></textarea>
                                        <span asp-validation-for="ListCurrencies" class="text-danger"></span>
                                    </div>
                                </div>
                                <br />


                                <h4 class="card-title">Provide information on the prevailing sales taxes/VAT if any.</h4><br />

                                <div class="questionText">
                                    Indicate whether taxes are included in the price as marked on item, or is added at time of purchase.
                                </div><br />


                                <table>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                <input id="TaxAddedAtPurchaseYes" type="radio" class="form-check-input" value=1 asp-for="TaxAddedAtPurchase"
                                                       onclick="if (this.checked) {document.getElementById('taxDetail').style.display = 'none'; }" />
                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>Price as marked on item<br /></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="custom-control custom-radio">
                                                <input id="TaxAddedAtPurchaseNo" type="radio" class="form-check-input" value=2 asp-for="TaxAddedAtPurchase"
                                                       onclick="if (this.checked) { document.getElementById('taxDetail').style.display = 'block';}" />
                                            </div>
                                        </td>
                                        <td> </td>
                                        <td>Tax added at time of purchase<br /></td>
                                    </tr>
                                </table>

                                <br />
                                <div id="taxDetail">
                                    <div class="questionText">
                                        If taxes vary by type of commodity, provide a list of the applicable taxes.
                                    </div><br />





                                    <table class="table table-sm table-borderless">
                                        <th>Commodity</th>
                                        <th>Tax</th>

                                        <tr>
                                            <td>
                                                <div class="form-group" style="margin-bottom:-4px">
                                                    <input id="c1" asp-for="Commodity1" class="form-control" />
                                                    <span asp-validation-for="Commodity1" class="text-danger"></span>
