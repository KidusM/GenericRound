@{
    ViewData["Title"] = "Create / Delete Round";
}

<div class="card">
    <div class="card-body">

        <div class="row">
            <div class="col-md-1">
            </div>

            <div class="col-md-10">
                <div class="container mt-4">

                    <h2>Create / Delete Round</h2>

                    @if (ViewBag.Message != null && ViewBag.RoundCreated != true && ViewBag.RoundDeleted != true)
                    {
                        <div class="alert alert-info mt-3">
                            @ViewBag.Message
                        </div>
                    }





                    <div class="alert alert-danger mt-4">
                        <h4>Important</h4>
                        <p>
                            Creating or deleting a Cost-of-Living Survey round changes the folder structure used by this Microsite.
                            This action can only be done by a Site Admin.
                        </p>
                    </div>








                    <div class="card border-primary mt-4">
                        <div class="card-header bg-info text-white">
                            Create New Round of Cost-of-Living Survey
                        </div>

                        <div class="card-body">
                            <div class="alert alert-warning border border-warning shadow-sm mt-4">
                                <h4 class="mb-3">
                                    <b> ⚠️ You are about to Create a new round of Surveys. </b>
                                </h4>

                                <p>
                                    Creating a new Cost-of-Living Survey round affects the Microsite structure used
                                    throughout the survey cycle. This action creates a new document repository and
                                    a new set of Welcome Pages for the selected round.
                                </p>

                                <p>
                                    This action should only be performed when a new survey round of surveys is officially launched
                                    and the corresponding survey materials are ready to be uploaded.
                                </p>



                            </div>

                            <form id="createRoundForm" asp-action="Index" asp-controller="CreateARound" method="post">

                                @Html.AntiForgeryToken()

                                <div class="form-group mb-3">
                                    <label>New Round Year</label>
                                    <input type="text"
                                           id="year"
                                           name="year"
                                           class="form-control"
                                           placeholder="Enter a new Round - YYYY" />
                                </div>

                                <button type="button"
                                        class="btn btn-info"
                                        data-bs-toggle="modal"
                                        data-bs-target="#createRoundModal">
                                    Review Create Request
                                </button>
                            </form>
                        </div>
                    </div>








                    <div class="card border-danger mt-5">
                        <div class="card-header bg-danger text-white">
                            Delete Round
                        </div>

                        <div class="card-body">
                            <div class="alert alert-danger">
                                <strong>Warning:</strong>
                                Removing a round permanently deletes the round folder and all empty subfolders.
                                Make sure there are no documents anywhere inside the folder by going to the
                                <a asp-controller="DocumentUpload" asp-action="Delete">Manage Documents</a> page.
                            </div>

                            @if (ViewBag.AvailableRounds != null && ViewBag.AvailableRounds.Count > 0)
                            {
                                <div class="alert alert-secondary">
                                    <strong>Available round folders:</strong>

                                    <div class="mt-2">
                                        @foreach (var round in ViewBag.AvailableRounds)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm me-2 mb-2"
                                                    onclick="document.getElementById('yearToDelete').value='@round'">
                                                @round Round of Surveys
                                            </button>
                                        }
                                    </div>

                                    <small class="text-muted">
                                        Click a folder above to fill the delete box.
                                    </small>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-secondary">
                                    No round folders were found.
                                </div>
                            }

                            <form id="deleteRoundForm"
                                  asp-action="DeleteRound"
                                  asp-controller="CreateARound"
                                  method="post">
                                @Html.AntiForgeryToken()

                                <div class="form-group mb-3">
                                    <label>Round Year to Delete</label>
                                    <input type="text"
                                           name="yearToDelete"
                                           id="yearToDelete"
                                           class="form-control"
                                           placeholder="Enter the Round to remove - YYYY" />
                                </div>

                                <button type="button"
                                        class="btn btn-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteRoundModal">
                                    Review Delete Request
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade"
                     id="createRoundModal"
                     tabindex="-1"
                     aria-labelledby="createRoundModalLabel"
                     aria-hidden="true">

                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-info">

                            <div class="modal-header bg-info text-white">
                                <h5 class="modal-title" id="createRoundModalLabel">
                                    Confirm Round Creation
                                </h5>

                                <button type="button"
                                        class="btn-close"
                                        data-bs-dismiss="modal"
                                        aria-label="Close">
                                </button>
                            </div>

                            <div class="modal-body">

                                <div class="alert alert-warning">
                                    <strong>This is a significant administrative action.</strong>
                                    <br />
                                    A new Cost-of-Living Survey round will be created.
                                </div>

                                <p>
                                    Creating a round will:
                                </p>

                                <ul>
                                    <li>Create a new document folder structure.</li>
                                    <li>Create a new Welcome Pages folder.</li>
                                    <li>Make the new round available throughout the Microsite.</li>
                                </ul>

                                <p>
                                    Please verify the round year before continuing.
                                </p>

                                <div class="alert alert-info mb-0">
                                    <strong>Selected Round:</strong>
                                    <span id="selectedCreateRoundPreview">Not selected</span>
                                </div>

                            </div>

                            <div class="modal-footer">

                                <button type="button"
                                        class="btn btn-secondary"
                                        data-bs-dismiss="modal">
                                    Cancel
                                </button>

                                <button type="submit"
                                        form="createRoundForm"
                                        class="btn btn-info">
                                    Yes, Create This Round
                                </button>

                            </div>

                        </div>
                    </div>
                </div>


                <div class="modal fade" id="roundCreatedModal" tabindex="-1" aria-labelledby="roundCreatedModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-success">

                            <div class="modal-header bg-success text-white">
                                <h5 class="modal-title" id="roundCreatedModalLabel">
                                    Round Created Successfully
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>

                            <div class="modal-body">
                                <div class="alert alert-success">
                                    <strong>Round @ViewBag.CreatedRound was created successfully.</strong>
                                </div>

                                <p>
                                    The new survey round folder structure has been created.
                                    The matching Welcome Pages folder has also been created.
                                </p>

                                <hr />

                                <h5>Required Follow-Up Tasks</h5>

                                <ol>
                                    <li>
                                        <strong>Update Welcome Pages</strong><br />
                                        Review and update the Welcome Page content for this new round.
                                    </li>

                                    <li class="mt-2">
                                        <strong>Update Documents</strong><br />
                                        Upload the documents that belong to this new survey round.
                                    </li>
                                </ol>
                            </div>

                            <div class="modal-footer">
                                <a asp-controller="Home"
                                   asp-action="Index"
                                   class="btn btn-success">
                                    I Understand
                                </a>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="modal fade"
                     id="roundDeletedModal"
                     tabindex="-1"
                     aria-labelledby="roundDeletedModalLabel"
                     aria-hidden="true">

                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-danger">

                            <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title" id="roundDeletedModalLabel">
                                    Round Deleted Successfully
                                </h5>

                                <button type="button"
                                        class="btn-close"
                                        data-bs-dismiss="modal"
                                        aria-label="Close">
                                </button>
                            </div>

                            <div class="modal-body">

                                <div class="alert alert-danger">
                                    <strong>Round @ViewBag.DeletedRound was deleted successfully.</strong>
                                </div>

                                <p>
                                    The survey round has been removed from the Microsite.
                                </p>

                                <ul>
                                    <li>The document folder structure was deleted.</li>
                                    <li>The Welcome Pages folder was deleted.</li>
                                    <li>The round is no longer available for administration.</li>
                                </ul>

                                <div class="alert alert-warning mb-0">
                                    This action cannot be undone.
                                </div>

                            </div>

                            <div class="modal-footer">

                                <a asp-controller="Home"
                                   asp-action="Index"
                                   class="btn btn-danger">
                                    I Understand
                                </a>

                            </div>

                        </div>
                    </div>
                </div>

                <div class="modal fade" id="deleteRoundModal" tabindex="-1" aria-labelledby="deleteRoundModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-danger">

                            <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title" id="deleteRoundModalLabel">
                                    Confirm Round Deletion
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>



                            <div class="modal-body">

                                <div class="alert alert-danger">
                                    <strong>You are about to delete a round of surveys.</strong>

                                </div>

                                <p>
                                    Deleting a round will:
                                </p>

                                <ul>
                                    <li>Delete the document folder structure for the round.</li>
                                    <li>Delete the Welcome Pages folder and its contents of the round.</li>
                                    <li>Remove the round from the Microsite folder structure.</li>
                                </ul>

                                <p>
                                    The system will refuse to delete the round if any document exists anywhere inside the document folder.
                                </p>

                                <p>
                                    Please verify the round year before continuing.
                                </p>

                                <div class="alert alert-warning mb-0">
                                    <strong>Selected Round:</strong>
                                    <span id="selectedRoundPreview">Not selected</span>
                                </div>

                            </div>

                            <div class="modal-footer">
                                <button type="button"
                                        class="btn btn-secondary"
                                        data-bs-dismiss="modal">
                                    Cancel
                                </button>

                                <button type="submit"
                                        form="deleteRoundForm"
                                        class="btn btn-danger">
                                    Yes, Delete This Round
                                </button>
                            </div>

                        </div>
                    </div>
                </div>

                @if (ViewBag.RoundCreated == true)
                {
                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            var roundCreatedModalElement = document.getElementById('roundCreatedModal');

                            if (roundCreatedModalElement) {
                                var roundCreatedModal = new bootstrap.Modal(roundCreatedModalElement);
                                roundCreatedModal.show();
                            }
                        });
                    </script>
                }
                @if (ViewBag.RoundDeleted == true)
                {
                    <script>
                        document.addEventListener('DOMContentLoaded', function () {

                            var roundDeletedModalElement =
                                document.getElementById('roundDeletedModal');

                            if (roundDeletedModalElement) {
                                var roundDeletedModal =
                                    new bootstrap.Modal(roundDeletedModalElement);

                                roundDeletedModal.show();
                            }
                        });
                    </script>
                }
                <script>
                    var deleteRoundModal = document.getElementById('deleteRoundModal');

                    if (deleteRoundModal) {
                        deleteRoundModal.addEventListener('show.bs.modal', function () {
                            var yearToDelete = document.getElementById('yearToDelete').value;
                            var preview = document.getElementById('selectedRoundPreview');

                            if (yearToDelete.trim() === '') {
                                preview.innerText = 'Not selected';
                            } else {
                                preview.innerText = yearToDelete;
                            }
                        });
                    }



                    var createRoundModal = document.getElementById('createRoundModal');

                    if (createRoundModal) {
                        createRoundModal.addEventListener('show.bs.modal', function () {

                            var year = document.getElementById('year').value;
                            var preview = document.getElementById('selectedCreateRoundPreview');

                            if (year.trim() === '') {
                                preview.innerText = 'Not selected';
                            }
                            else {
                                preview.innerText = year;
                            }
                        });
                    }

                </script>


            </div>

            <div class="col-md-1"></div>
        </div>

    </div>
</div>