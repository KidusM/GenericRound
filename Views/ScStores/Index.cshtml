@model IEnumerable<CSMS.Models.ScStores>

@{
    ViewData["Title"] = "Index";
}
<div class="container">
    <h2>Index</h2>

    <p>
        <a asp-action="Create">Create New</a>
    </p>
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.DsId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.StoresId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.StoresName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.StoresDescription)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.StoreAddress)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.WebAddress)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.GpsCoordinates)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.OutletTypeId)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.DsId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StoresId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StoresName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StoresDescription)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StoreAddress)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.WebAddress)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.GpsCoordinates)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.OutletTypeId)
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>