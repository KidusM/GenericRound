@model CSMS.Models.DutyStation

@{
    ViewData["Title"] = "Edit";
}
<div class="container">
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-2"></div>
                <div class="col-md-8">
                    <br />
                    <h2 class="card-title text-center">Edit Duty Station</h2>
                </div>
                <div class="col-md-2"></div>
            </div>

        </div>
    </div>



    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-2"></div>

                <div class="col-md-8">


                    <div class="table-responsive m-t-40">

                        <form asp-action="Edit">

                            <table class="table table-borderless table-sm">
                                <tbody>

                                    <tr>
                                        <td>
                                            <input type="hidden" asp-for="Dsid" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td> <label asp-for="Dsid" class="control-label"></label></td>
                                        <td>
                                            <input asp-for="Dsid" class="form-control" />
                                            <span asp-validation-for="Dsid" class="text-danger"></span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td> <label asp-for="Country" class="control-label"></label></td>
                                        <td>
                                            <input asp-for="Country" class="form-control" />
                                            <span asp-validation-for="Dsid" class="text-danger"></span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td> <label asp-for="City" class="control-label"></label></td>
                                        <td>
                                            <input asp-for="City" class="form-control" />
                                            <span asp-validation-for="Dsid" class="text-danger"></span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td> <label asp-for="Dsgroup" class="control-label"></label></td>
                                        <td>
                                            <input asp-for="Dsgroup" class="form-control" />
                                            <span asp-validation-for="Dsid" class="text-danger"></span>
                                        </td>
                                    </tr>
                            </table>

                            <div class="form-group">
                                <input type="submit" value="Save" class="btn btn-primary" /> <a asp-action="Index" class="btn btn-info">Back to List</a>
                            </div>
                            <div class="form-group">

                            </div>




                        </form>

                    </div>

                </div>

                <div class="col-md-2"></div>

            </div>
        </div>
    </div>
    @*@section Scripts {
            @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
        }*@
</div>